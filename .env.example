# MPGV Monitor environment reference. Copy values into a private, ignored file
# on the target machine; do not commit real production secrets.

# Required production mode switch. Use "development" only for direct local dev.
APP_ENV=production

# Required in production for maintenance routes:
# /reconcile, /scrape-volcanoes, /initialize-data.
# Generate a long random value; never expose it in URLs or frontend code.
ADMIN_TOKEN=

# Development-only convenience. Leave false in production.
ALLOW_DEV_LOCAL_ADMIN=false

# Pluto/nginx topology: set to 1 only when exactly one trusted reverse proxy is
# in front of Gunicorn and Gunicorn is not directly public. Use 0 for direct dev.
TRUSTED_PROXY_COUNT=0

# Local/default ports.
BACKEND_PORT=5001
FRONTEND_PORT=5174

# Scheduler and runtime state.
DISABLE_SCHEDULER=
RUNTIME_DIR=backend/runtime

# SQLite/API bounds.
MAX_DAYS_WINDOW=3650
EARTHQUAKES_MAX_ROWS=20000
CSV_MAX_DAYS_WINDOW=3650
CSV_MAX_ROWS=50000
MIN_VALID_VOLCANO_ROWS=5

# Flask-Limiter. memory:// is supported for local and current single-process
# deployment; use shared storage such as Redis before multiple workers/instances.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory://
RATE_LIMIT_DEFAULT=300 per minute
RATE_LIMIT_EARTHQUAKES=120 per minute
RATE_LIMIT_VOLCANOES=120 per minute
RATE_LIMIT_SHAKEMAP=60 per minute
RATE_LIMIT_CSV=10 per minute
RATE_LIMIT_ADMIN=5 per minute
