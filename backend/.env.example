# Backend runtime settings

# Production mode requires a long private token for state-changing maintenance
# routes. Direct local development can use APP_ENV=development and the explicit
# loopback fallback instead; never enable that fallback on Pluto.
APP_ENV=production
ADMIN_TOKEN=
ALLOW_DEV_LOCAL_ADMIN=false

# Set to 1 only when exactly one trusted reverse proxy is confirmed in front of
# loopback-bound Gunicorn. Keep 0 for direct local development.
TRUSTED_PROXY_COUNT=0

# Disable APScheduler in tests or one-off maintenance runs.
DISABLE_SCHEDULER=0

# API request rate limiting.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=300 per minute
RATE_LIMIT_EARTHQUAKES=120 per minute
RATE_LIMIT_VOLCANOES=120 per minute
RATE_LIMIT_SHAKEMAP=60 per minute
RATE_LIMIT_CSV=10 per minute
RATE_LIMIT_ADMIN=5 per minute

# API and export query bounds.
MAX_DAYS_WINDOW=3650
EARTHQUAKES_MAX_ROWS=20000
CSV_MAX_DAYS_WINDOW=3650
CSV_MAX_ROWS=50000
MIN_VALID_VOLCANO_ROWS=5

# Local development and single-process deployments can use memory://.
# Multi-worker or multi-server production deployments should use shared storage.
RATE_LIMIT_STORAGE=memory://
# RATE_LIMIT_STORAGE=redis://redis-host:6379/0
