# Backend runtime settings

# Set in production to protect maintenance endpoints.
ADMIN_TOKEN=change-me-outside-git

# Disable APScheduler in tests or one-off maintenance runs.
DISABLE_SCHEDULER=0

# API request rate limiting.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=300 per minute
RATE_LIMIT_EARTHQUAKES=120 per minute
RATE_LIMIT_VOLCANOES=120 per minute
RATE_LIMIT_SHAKEMAP=60 per minute
RATE_LIMIT_CSV=10 per minute

# Local development and single-process deployments can use memory://.
# Multi-worker or multi-server production deployments should use shared storage.
RATE_LIMIT_STORAGE=memory://
# RATE_LIMIT_STORAGE=redis://redis-host:6379/0
